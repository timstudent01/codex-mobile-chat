{
  "name": "codex-mobile-chat",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "dev:hot": "bun --hot src/server.ts",
    "kill:3000": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-port-3000.ps1",
    "dev:clean": "bun run kill:3000; bun --watch src/server.ts",
    "start": "bun run src/server.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.9",
    "marked": "^17.0.5"
  }
}
